# AI Provider selection: 'ollama', 'groq', 'gemini', 'openai'
NOVA_PROVIDER=ollama

# Ollama local settings
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi3

# Wake Word Settings
# Set to true to enable listening for the wake word (requires SpeechRecognition + PyAudio)
WAKE_WORD_ENABLED=false
WAKE_WORD=hey nova


# API Keys (Optional fallbacks if not using Ollama)
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Default User Name
USER_NAME=Bharath
